# ──────────────────────────────────────────────
# jellyfin-mcp-helper — Configuration
# ──────────────────────────────────────────────
# Copy this file to .env and fill in your values.
#   cp .env.example .env
# ──────────────────────────────────────────────

# ── AI / Classification ───────────────────────
# Required: API key for OpenRouter (get one at https://openrouter.ai/)
# Only needed when MODEL_PROVIDER=openrouter.
# OPENROUTER_API_KEY=

# Model provider: "ollama" (default) or "openrouter"
MODEL_PROVIDER=ollama

# Model mode (keep as "external-classifier")
MODEL_MODE=external-classifier

# Base URL for the model API (Ollama default: http://localhost:11434)
MODEL_BASE_URL=http://localhost:11434

# Model name to use (default: llama3.2:1b)
MODEL_NAME=llama3.2:1b

# Model temperature (0 = deterministic)
MODEL_TEMPERATURE=0

# Confidence threshold for classification (0.0 - 1.0)
MODEL_CLASSIFY_CONFIDENCE_THRESHOLD=0.65
MODEL_PATH_CONFIDENCE_THRESHOLD=0.6

# Timeout and retries for model API calls
MODEL_REQUEST_TIMEOUT_SECONDS=120
MODEL_RETRY_ATTEMPTS=2

# ── Download Client (qBittorrent via MCP) ─────
# Toggle: set to "true" to enable download client checks
ENABLE_DOWNLOAD_CLIENT_CHECK=true

# Download client type: "qbittorrent" (default)
DOWNLOAD_CLIENT=qbittorrent

# MCP endpoint for qBittorrent
QBT_MCP_URL=http://localhost:8093/mcp

# API key for qBittorrent MCP
QBT_MCP_API_KEY=

# Optional: qBittorrent WebUI credentials (used for some operations)
# QBT_WEBUI_USER=
# QBT_WEBUI_PASS=

# ── Jellyfin Integration (optional) ───────────
# Set to "true" to auto-scan Jellyfin libraries after moving files
ENABLE_JELLYFIN_INTEGRATION=true

# Jellyfin server URL
JELLYFIN_BASE_URL=http://localhost:8096

# Jellyfin API key (create one in Jellyfin Dashboard > API Keys)
JELLYFIN_API_KEY=

# Library names as configured in Jellyfin
JELLYFIN_MOVIE_LIBRARY_NAME=Movies
JELLYFIN_SERIES_LIBRARY_NAME=Shows

# ── Storage Paths ─────────────────────────────
# Comma-separated paths where torrent downloads reside
DOWNLOAD_ROOTS=/media/torrents

# Comma-separated paths where organised movies are stored
MOVIE_ROOTS=/media/movies

# Comma-separated paths where organised series are stored
SERIES_ROOTS=/media/series
