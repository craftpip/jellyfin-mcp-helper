# Required - get from https://openrouter.ai/
OPENROUTER_API_KEY=

# Download client (e.g., qbittorrent) - required for stopping active downloads
# Set DOWNLOAD_CLIENT=qbittorrent to use qBittorrent via MCP
DOWNLOAD_CLIENT=qbittorrent
QBT_MCP_URL=http://host.docker.internal:8093/mcp
QBT_MCP_API_KEY=

# Jellyfin - optional, for triggering library scans after moving
JELLYFIN_BASE_URL=
JELLYFIN_API_KEY=
JELLYFIN_MOVIE_LIBRARY_NAME=Movies
JELLYFIN_SERIES_LIBRARY_NAME=Shows

# Model config - AI classification
MODEL_PROVIDER=ollama
MODEL_MODE=external-classifier
MODEL_BASE_URL=http://localhost:11434
MODEL_NAME=llama3.2:1b
MODEL_TEMPERATURE=0
MODEL_CLASSIFY_CONFIDENCE_THRESHOLD=0.65
MODEL_PATH_CONFIDENCE_THRESHOLD=0.6
MODEL_REQUEST_TIMEOUT_SECONDS=120
MODEL_RETRY_ATTEMPTS=2

# Paths config - comma-separated paths (can be docker volume paths)
DOWNLOAD_ROOTS=/downloads
MOVIE_ROOTS=/downloads/movies
SERIES_ROOTS=/downloads/series